{
  "name": "tagwise",
  "version": "0.1.0",
  "description": "Desktop app for scanning and fixing music library tags",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron ."
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.tagwise.app",
    "productName": "Tagwise",
    "files": ["dist/**/*", "electron/**/*"],
    "directories": { "output": "release" }
  }
}